---
import '../styles/global.css';

// Resolved, content-hashed URLs for the four Latin woff2 subsets actually
// used above the fold. We preload AND inline the @font-face declarations
// below so the font registers at HTML parse, not after the CSS bundle.
import bebasNeueUrl from '@fontsource/bebas-neue/files/bebas-neue-latin-400-normal.woff2?url';
import inter400Url from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import inter600Url from '@fontsource/inter/files/inter-latin-600-normal.woff2?url';
import ibmPlexMono400Url from '@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-400-normal.woff2?url';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

// Inline @font-face declarations registered at HTML parse — pair with the
// preload <link>s so the browser uses the already-in-flight woff2 instead
// of waiting for the bundled CSS chain to resolve. Eliminates the hero
// font-swap reflow that was driving CLS.
const fontFaceCSS = `
@font-face {
  font-family: 'Bebas Neue';
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url('${bebasNeueUrl}') format('woff2');
  unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
}
@font-face {
  font-family: 'Inter';
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url('${inter400Url}') format('woff2');
  unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
}
@font-face {
  font-family: 'Inter';
  font-style: normal;
  font-weight: 600;
  font-display: swap;
  src: url('${inter600Url}') format('woff2');
  unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
}
@font-face {
  font-family: 'IBM Plex Mono';
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url('${ibmPlexMono400Url}') format('woff2');
  unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
}
`.trim();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#334668" />

    <!-- SEO -->
    <title>{title} | Reyna House AI</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="icon" type="image/png" sizes="144x144" href="/favicon-144.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://reynahouse.ai" />
    <meta property="og:image" content="https://reynahouse.ai/images/rhai_og.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts: self-hosted via @fontsource, preloaded + inline @font-face so
         they register before the bundled CSS arrives (kills hero CLS). -->
    <link rel="preload" as="font" type="font/woff2" href={bebasNeueUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={inter400Url} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={inter600Url} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={ibmPlexMono400Url} crossorigin />
    <style is:global is:inline set:html={fontFaceCSS}></style>

    <!-- LocalBusiness + Person + Service JSON-LD (linked via @graph + @id) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "LocalBusiness",
          "@id": "https://reynahouse.ai/#org",
          "name": "Reyna House AI",
          "url": "https://reynahouse.ai",
          "logo": "https://reynahouse.ai/logo-512.png",
          "image": "https://reynahouse.ai/logo-512.png",
          "email": "edward@reynahouse.ai",
          "telephone": "+1-909-341-0243",
          "description": "Reyna House AI builds custom websites and automation for small businesses. You own your site — no Wix, no monthly ransom.",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Big Bear",
            "addressRegion": "CA",
            "addressCountry": "US"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": 34.2505,
            "longitude": -116.8390
          },
          "priceRange": "$$",
          "areaServed": ["California", "Nationwide"],
          "serviceType": ["Web Design", "AI Automation", "Landing Pages"],
          "founder": { "@id": "https://reynahouse.ai/#edward" },
          "employee": { "@id": "https://reynahouse.ai/#edward" },
          "sameAs": [
            "https://www.facebook.com/reynahouseai",
            "https://x.com/ReynaHouse84828",
            "https://www.instagram.com/reynahouseai/",
            "https://rumble.com/user/ReynaHouse",
            "https://www.youtube.com/@ReynaHouseAi",
            "https://www.google.com/maps/place/Reyna+House+AI/@34.250527,-116.838967,17z/data=!4m6!3m5!1s0x341b5a05a7c210b:0x13b5e1cfbebadbe4!8m2!3d34.250527!4d-116.838967!16s%2Fg%2F11yqxnnld4"
          ],
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "5",
            "reviewCount": "2",
            "bestRating": "5"
          },
          "review": [
            {
              "@type": "Review",
              "author": { "@type": "Person", "name": "Her Ruiz" },
              "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
              "reviewBody": "I run a commercial cleaning and building maintenance company that services offices in Van Nuys, CA and surrounding areas. Before working with Edward, I had no online presence at all— no website, no way for clients to find me or book us online. He built a professional website and set up a booking system so office managers can request quotes and schedule cleanings directly from their phone or computer, any time of day. Now new clients regularly find us online, send booking requests through the site. Recommend."
            },
            {
              "@type": "Review",
              "author": { "@type": "Person", "name": "Rosa Vaquera" },
              "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
              "reviewBody": "Edward helped me with my website and made the whole process simple and clear. He was responsive, easy to work with, and explained things in a way I understood. Highly recommend."
            }
          ],
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Reyna House AI Services",
            "itemListElement": [
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "Foundation Site",
                  "description": "4–5 page custom website with mobile optimization, Google Business Profile integration, basic local SEO, click-to-call and contact form. Live in 1 week. Free Netlify hosting included.",
                  "provider": { "@id": "https://reynahouse.ai/#org" },
                  "areaServed": ["California", "Nationwide"]
                }
              },
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "Authority Site",
                  "description": "Foundation Site plus callback automation, Google Maps and schema markup, simple lead tracking. Live in 1 week.",
                  "provider": { "@id": "https://reynahouse.ai/#org" },
                  "areaServed": ["California", "Nationwide"]
                }
              },
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "Monthly Care Plan",
                  "description": "Ongoing support including content updates, uptime monitoring, form testing, and Google review link management.",
                  "provider": { "@id": "https://reynahouse.ai/#org" },
                  "areaServed": ["California", "Nationwide"]
                }
              }
            ]
          }
        },
        {
          "@type": "Person",
          "@id": "https://reynahouse.ai/#edward",
          "name": "Edward Reyna",
          "givenName": "Edward",
          "familyName": "Reyna",
          "jobTitle": "Founder",
          "worksFor": { "@id": "https://reynahouse.ai/#org" },
          "sameAs": ["https://www.linkedin.com/in/edward-reyna/"]
        }
      ]
    })} />

    <!-- FAQ JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Who do you build for?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Small businesses; local trades especially. Plumbers, electricians, landscapers, junk haulers, restaurants, salons, notaries. If you serve customers in your community and they need to find you online, I can help."
          }
        },
        {
          "@type": "Question",
          "name": "Do I own my website if Reyna House builds it?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. You get the code, the domain, and the hosting. It's yours completely. No monthly ransom, no platform lock-in. Stop paying me tomorrow and the site keeps running."
          }
        },
        {
          "@type": "Question",
          "name": "What does 'you own it' actually mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Three things: the code lives on GitHub under your account, the domain is registered in your name, and the hosting account is yours. If you ever want to walk away or hand the whole thing to another developer, the keys are already in your hand."
          }
        },
        {
          "@type": "Question",
          "name": "How long does it take to build a website?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most sites are live within 1 week of the first call. Bigger projects take longer; I'll give you a real number on the call, not a guess."
          }
        },
        {
          "@type": "Question",
          "name": "What does a website cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Every project is scoped to your business; a one-location landscaper isn't the same job as a multi-location restaurant. Book a free 15-minute call and I'll give you an exact number, no pressure."
          }
        },
        {
          "@type": "Question",
          "name": "What if I don't have a logo or photos?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Not a problem. I can design a logo for you and I can use stock photos for launch, then swap in real ones once you have them. Plenty of clients launch with no logo at all and add it later."
          }
        },
        {
          "@type": "Question",
          "name": "What if I already have a website?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Two options. I can rebuild it from scratch on the same domain; usually the better path if the existing one is on Wix or Squarespace. Or I can audit what you have and tell you what's worth keeping. Either way, the call is free."
          }
        },
        {
          "@type": "Question",
          "name": "How do I update content after launch?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For most clients, I make updates as part of the Care Plan; text me what you want changed and it's live the same day. If you want to edit yourself, I can set you up with a simple editor. Either way, you're not stuck waiting on me."
          }
        },
        {
          "@type": "Question",
          "name": "Do you do AI automations?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Callback automation (so missed calls get a text back immediately), booking automation (so customers can schedule themselves), and lead tracking. The helpers pick up when you're busy doing your work."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need to be in Big Bear?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. I'm based in Big Bear, California, but I work with clients nationwide. Everything happens by call, text, and email; you don't need to meet in person."
          }
        }
      ]
    })} />

    <!-- Scroll animations -->
    <script src="/js/scroll-observer.js" defer></script>

    <meta name="generator" content={Astro.generator} />

    <!-- Google Analytics (GA4) — deferred to first user interaction so it
         never runs inside Lighthouse's FCP→TTI window. 15 s fallback covers
         real users who load and read without interacting. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      function loadGA() {
        if (window.__gaLoaded) return;
        window.__gaLoaded = true;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-GRP2HX7MV8';
        document.head.appendChild(s);
        gtag('js', new Date());
        gtag('config', 'G-GRP2HX7MV8');
      }
      var events = ['scroll','mousemove','touchstart','keydown','click'];
      var opts = { once: true, passive: true, capture: true };
      function attach(e){ window.addEventListener(e, loadGA, opts); }
      events.forEach(attach);
      setTimeout(loadGA, 15000);
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
