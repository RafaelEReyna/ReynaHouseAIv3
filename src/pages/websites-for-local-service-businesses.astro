---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Live spokes link out; the rest are named in prose for coverage until built.
const spokes = [
  {
    href: "/websites-for-contractors/",
    title: "For Contractors",
    body: "General contractors and the building trades, built to turn searches into booked jobs.",
  },
  {
    href: "/websites-for-plumbers/",
    title: "For Plumbers",
    body: "Built so the emergency call and the booked service job find you first.",
  },
  {
    href: "/websites-for-hair-salons/",
    title: "For Hair Salons",
    body: "Built around online booking and a gallery of your work, so new clients find a chair and fill it.",
  },
];

const faqs = [
  {
    q: "What kinds of businesses do you build websites for?",
    a: "Local service businesses of almost every kind: contractors, plumbers, electricians, roofers, HVAC companies, landscapers, painters, concrete crews, remodelers, commercial cleaning companies, hair salons, barbershops, nail salons, and more. The common thread is simple: if your customers find you by searching online and then calling or booking, a website built the right way will bring you more of them. The trade shapes how the site is built, but the goal is always the same: get found in your area and make it easy to take the next step. If you're not sure whether your business fits, it almost certainly does. Book a free call, tell me what you do, and I'll tell you straight how a website would help.",
  },
  {
    q: "Do I own my website?",
    a: "When your website is finished, you own the code, your domain name, and your hosting account. Nothing is rented and you're never locked into a monthly website subscription. Most website builders work differently. You pay every month, but the website isn't truly yours. If you stop paying, the site often disappears. I build websites in clean code that you own outright. If you ever decide to work with someone else, you can. Your website belongs to your business, not to me.",
  },
  {
    q: "Do you build websites for businesses in other states?",
    a: "Yes. I'm based in Big Bear, California, but I build websites for local service businesses all over the United States. Because everything is done by phone, email, and video call, we never need to meet in person and your location is never a problem. When we get on our first call, I learn your trade, the towns and counties you serve, and the kind of work you want more of. Then I build your website around those local searches, so the people in your area looking for your service have a better chance of finding you. Every website is built around your local market, your services, and the customers you're trying to reach, not around my location.",
  },
  {
    q: "How much does a website cost?",
    a: "It depends on your business, so I won't throw out a number that turns out wrong. Here's the honest range you'll see in the market: on the cheap end, builders like Wix run around $30 a month forever, and you never own the site. On the high end, large agencies charge $10,000 or more, often with an ongoing monthly retainer attached. I build custom websites that you own outright and price them in between, with one clear number scoped to your business. Before I quote anything, I learn your trade and your service area on a free call, so the price reflects your actual business instead of a guess. If you want the full breakdown, I wrote a plain English guide on what goes into website pricing.",
  },
];
---

<Layout
  title="Websites for Local Service Businesses"
  description="Custom coded websites for local service businesses across the United States, built for Google Search to turn searches into calls and booked jobs. You own everything; no monthly rental. Built in the USA."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Website Design for Local Service Businesses",
      "serviceType": "Website design for local service businesses",
      "provider": { "@id": "https://reynahouse.ai/#org" },
      "areaServed": ["United States"],
      "description": "Custom coded websites for local service businesses, built for Google Search to convert searches into calls and booked jobs. The owner keeps the code, domain, and hosting outright.",
      "url": "https://reynahouse.ai/websites-for-local-service-businesses/",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://reynahouse.ai/" },
        { "@type": "ListItem", "position": 2, "name": "Local Service Businesses", "item": "https://reynahouse.ai/websites-for-local-service-businesses/" },
      ],
    })} />
  </Fragment>

  <Header />

  <main class="page">
    <!-- HERO -->
    <article class="intro">
      <div class="intro__container">
        <nav class="crumbs" aria-label="Breadcrumb">
          <a href="/">Home</a> <span aria-hidden="true">/</span> Local Service Businesses
        </nav>
        <span class="overline">BUILT FOR LOCAL BUSINESS</span>
        <h1 class="h1">Websites for Local Service Businesses</h1>
        <p class="lede">
          If your business lives on phone calls, quote requests, and booked
          appointments, your website has one job: help the right customers find
          you and reach you before they call someone else.
        </p>
        <p class="body body--gold">
          I build custom coded websites for local service businesses, designed
          around how your customers actually search, so you get found on Google
          and turn that traffic into real work.
        </p>
      </div>
    </article>

    <!-- SPOKE DIRECTORY -->
    <section class="section">
      <div class="section__container">
        <h2 class="h2">Find Your Trade</h2>
        <p class="body">
          Every trade is a little different, so I build each site around the way
          your customers search and the work you want more of. Here's where to
          start.
        </p>
        <div class="cards">
          {spokes.map((s) => (
            <a class="card card--link" href={s.href}>
              <h3 class="card__title">{s.title}</h3>
              <p class="card__body">{s.body}</p>
              <span class="card__cta">See more &rarr;</span>
            </a>
          ))}
          <a class="card card--link" href="/#contact">
            <h3 class="card__title">Don't See Your Trade?</h3>
            <p class="card__body">Electricians, roofers, HVAC, landscapers, painters, salons, and more. If you're a local service business, I can build for you.</p>
            <span class="card__cta">Book a free call &rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- WHO THIS IS FOR -->
    <section class="section section--tint">
      <div class="section__container">
        <h2 class="h2">Who This Is For</h2>
        <p class="body">
          I build websites for the businesses that grow on local customers and
          repeat work: home and trade services like plumbing, electrical,
          roofing, HVAC, landscaping, concrete, painting, remodeling, and
          flooring; commercial services like cleaning and building maintenance;
          and appointment businesses like hair salons, barbershops, and nail
          salons.
        </p>
        <p class="body">
          The thread that ties them together is simple. A single new customer is
          worth real money to you, and most of those customers start by searching
          online. A website built around your service area and your services
          gives you a better chance of being the one they find and call.
        </p>
      </div>
    </section>

    <!-- WHY DIFFERENT -->
    <section class="section section--dark">
      <div class="section__container">
        <span class="overline overline--light">WHY MINE IS DIFFERENT</span>
        <h2 class="h2 h2--light">Built in the USA, and You Own It</h2>
        <p class="body body--light">
          Many low cost website companies reduce prices by outsourcing
          development overseas or locking businesses into monthly website rentals.
        </p>
        <p class="body body--light">
          I build every website myself in the United States using clean code. When
          the project is finished, you own it. If you ever need help, I'm still
          here because I've earned your business, not because you're trapped.
        </p>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="section">
      <div class="section__container">
        <h2 class="h2">How It Works</h2>
        <div class="steps">
          <div class="step">
            <h3>Book a Free Call</h3>
            <p>Tell me about your trade, service area, and goals.</p>
          </div>
          <div class="step">
            <h3>Receive a Fixed Proposal</h3>
            <p>You'll receive one clear price with exactly what's included.</p>
          </div>
          <div class="step">
            <h3>Launch Your Website</h3>
            <p>Most websites are completed in about a week. After your review, your site launches under your ownership.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section section--cta">
      <div class="section__container">
        <h2 class="h2">Ready for More Calls?</h2>
        <p class="body">
          Tell me your trade and your service area, and I'll show you what a
          website built for Google Search can do for your business. Book a free
          call; no pressure, no obligation.
        </p>
        <div class="cta__actions">
          <a href="/#contact" class="btn btn--primary">Book a Free Call &rarr;</a>
          <a href="tel:+19093410243" class="btn btn--ghost">Or call 909-341-0243</a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section section--tint">
      <div class="section__container section__container--narrow">
        <h2 class="h2">Common Questions</h2>
        {faqs.map((f) => (
          <details class="faq">
            <summary class="faq__q">{f.q}</summary>
            <p class="faq__a">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- RELATED -->
    <section class="related">
      <div class="related__container">
        <p class="related__title">Keep Reading</p>
        <div class="related__grid">
          <a class="related__card" href="/small-business-website-cost/">
            <span>What Does a Small Business Website Cost?</span>
            <small>The four ways to buy one, and the rent versus own trap.</small>
          </a>
          <a class="related__card" href="/missed-call-text-back/">
            <span>Missed Call Text Back</span>
            <small>Stop losing jobs to voicemail when you can't pick up.</small>
          </a>
          <a class="related__card" href="/why-not-showing-on-google/">
            <span>Why Isn't My Business on Google?</span>
            <small>The usual reasons, and how to fix them.</small>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page { background-color: var(--white); }
  .intro { background: linear-gradient(135deg, var(--navy) 0%, #1a1a2e 100%); padding: 72px 24px 64px; }
  .intro__container { max-width: 820px; margin: 0 auto; }
  .crumbs { font-family: 'IBM Plex Mono', monospace; font-size: 0.75rem; color: var(--tan); margin-bottom: 24px; }
  .crumbs a { color: var(--copper-light); }
  .crumbs a:hover { color: var(--copper); }
  .overline { display: block; font-family: 'IBM Plex Mono', monospace; color: var(--copper-light); text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.75rem; margin-bottom: 16px; }
  .h1 { font-family: 'Bebas Neue', sans-serif; color: var(--white); font-size: clamp(2.2rem, 6vw, 3.6rem); line-height: 1.05; margin-bottom: 24px; }
  .lede { font-family: 'Inter', sans-serif; color: var(--white); font-size: 1.15rem; line-height: 1.7; margin-bottom: 16px; }
  .section { padding: 64px 24px; }
  .section--tint { background-color: var(--cream); }
  .section--dark { background: linear-gradient(135deg, var(--forest) 0%, #1a2a1c 100%); }
  .section--cta { background-color: var(--white); text-align: center; }
  .section__container { max-width: 920px; margin: 0 auto; }
  .section__container--narrow { max-width: 760px; }
  .h2 { font-family: 'Bebas Neue', sans-serif; color: var(--navy); font-size: clamp(1.8rem, 4.5vw, 2.6rem); line-height: 1.1; margin-bottom: 20px; }
  .h2--light { color: var(--white); }
  .body { font-family: 'Inter', sans-serif; color: var(--dark); font-size: 1.05rem; line-height: 1.75; margin-bottom: 16px; }
  .body--light { color: var(--cream); }
  .body--gold { color: var(--gold); font-weight: 600; }

  .cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 28px; }
  .card { background: var(--white); border: 1px solid var(--tan); border-radius: 10px; padding: 24px; display: block; transition: border-color 0.2s ease, transform 0.2s ease; }
  .card--link:hover { border-color: var(--copper); transform: translateY(-2px); }
  .card__title { font-family: 'Bebas Neue', sans-serif; color: var(--navy); font-size: 1.5rem; letter-spacing: 0.02em; margin-bottom: 10px; line-height: 1.1; }
  .card__body { font-family: 'Inter', sans-serif; color: var(--dark); font-size: 0.95rem; line-height: 1.6; margin-bottom: 14px; }
  .card__cta { font-family: 'IBM Plex Mono', monospace; color: var(--copper-dark); font-size: 0.82rem; font-weight: 600; }

  .steps { display: grid; gap: 16px; margin-top: 28px; counter-reset: step; }
  .step { position: relative; padding: 20px 20px 20px 68px; background: var(--white); border: 1px solid var(--tan); border-radius: 10px; }
  .step::before { counter-increment: step; content: counter(step); position: absolute; left: 20px; top: 20px; width: 34px; height: 34px; display: grid; place-items: center; background: var(--copper); color: var(--white); font-family: 'Bebas Neue', sans-serif; font-size: 1.25rem; border-radius: 50%; }
  .step h3 { font-family: 'Inter', sans-serif; font-weight: 600; color: var(--navy); font-size: 1.05rem; margin-bottom: 6px; }
  .step p { font-family: 'Inter', sans-serif; color: var(--dark); font-size: 0.95rem; line-height: 1.6; }

  .cta__actions { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; margin-top: 28px; }
  .btn { font-family: 'Inter', sans-serif; font-weight: 600; font-size: 1rem; padding: 14px 26px; border-radius: 8px; transition: background-color 0.2s ease, color 0.2s ease; }
  .btn--primary { background-color: var(--copper); color: var(--white); }
  .btn--primary:hover { background-color: #b8843f; }
  .btn--ghost { border: 1px solid var(--navy); color: var(--navy); }
  .btn--ghost:hover { background-color: var(--navy); color: var(--white); }
  .btn:focus-visible { outline: 2px solid var(--copper); outline-offset: 2px; }

  .faq { border-bottom: 1px solid var(--tan); padding: 16px 0; }
  .faq__q { font-family: 'IBM Plex Mono', monospace; color: var(--copper-dark); font-size: 0.95rem; cursor: pointer; list-style: none; padding: 4px 0; }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::before { content: '+ '; font-weight: 700; }
  details[open] .faq__q::before { content: '− '; }
  .faq__a { font-family: 'Inter', sans-serif; color: var(--navy); font-size: 0.97rem; line-height: 1.7; padding: 12px 0 4px; }

  .related { background: var(--cream); padding: 48px 24px; }
  .related__container { max-width: 920px; margin: 0 auto; }
  .related__title { font-family: 'IBM Plex Mono', monospace; color: var(--copper-dark); font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
  .related__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .related__card { display: block; background: var(--white); border: 1px solid var(--tan); border-radius: 10px; padding: 18px; transition: border-color 0.2s ease; }
  .related__card:hover { border-color: var(--copper); }
  .related__card span { font-family: 'Inter', sans-serif; font-weight: 600; color: var(--navy); font-size: 1rem; line-height: 1.3; }
  .related__card small { display: block; font-family: 'Inter', sans-serif; color: var(--dark); font-size: 0.85rem; margin-top: 6px; line-height: 1.5; }

  @media (max-width: 700px) {
    .cards { grid-template-columns: 1fr; }
    .related__grid { grid-template-columns: 1fr; }
  }
</style>
