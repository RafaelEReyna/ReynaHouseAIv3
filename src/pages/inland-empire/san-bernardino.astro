---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import bedrockShot from '../../assets/images/bedrock_concrete_hero.jpg';
import ridgelineShot from '../../assets/images/ridgeline_hvac_hero.jpg';

const trades = [
  "General contractors", "Concrete contractors", "Plumbers", "HVAC companies",
  "Roofers", "Electricians", "Landscapers", "Painters", "Cleaning companies",
];

const proof = [
  {
    img: bedrockShot,
    href: "https://bedrock-concrete-showcase.netlify.app/",
    label: "Concrete contractor · San Bernardino",
    note: "A San Bernardino concrete contractor site built to turn a search into a quote request, with a page for every pour and the towns it covers.",
  },
  {
    img: ridgelineShot,
    href: "https://ridgeline-hvac-showcase.netlify.app/",
    label: "HVAC company · Inland Empire",
    note: "An Inland Empire HVAC site with fast tap to call for the no cool and no heat calls that come in from a phone.",
  },
];

const faqs = [
  {
    q: "Do you build websites for San Bernardino contractors?",
    a: "Yes. I build custom websites for San Bernardino contractors and local service businesses, from concrete and roofing crews to plumbers, electricians, and HVAC companies. I'm based right above the city in Big Bear, so San Bernardino is home turf, and the mountain road runs straight through it. Everything is handled by phone, text, email, and video call, so we build your site around the San Bernardino searches your customers make without ever needing to meet in person.",
  },
  {
    q: "Are you actually located in San Bernardino?",
    a: "No, and I won't pretend to be. Reyna House AI is based in Big Bear, California, just up the mountain from San Bernardino, and I serve the city as a service area business rather than from a storefront. That keeps my overhead low and puts the money into a website you own outright. San Bernardino is the closest major Inland Empire city to my base, so the local searches your customers make are the ones I build your site around.",
  },
  {
    q: "Why does a San Bernardino service business need a better website?",
    a: "In San Bernardino your next customer usually searches Google before they ever call, and the business with the clearer, faster website tends to get the call. Plenty of established local shops still run on an old site that loads slowly on a phone or does not show up when someone searches their service and city. A website built the right way helps those customers find you first and makes it dead simple to tap and call, so the job does not go to the next company on the list.",
  },
  {
    q: "How long does a San Bernardino website take to build?",
    a: "Most websites are live within about a week of our first call, built around your services and your San Bernardino service area. A larger project with many service pages, multiple locations, or online booking takes a little longer, and I give you a real timeline in your proposal instead of a vague promise. I build in clean code myself, so there is no committee and no back and forth with a team overseas slowing things down.",
  },
  {
    q: "Do I own the website?",
    a: "Yes. You own the code, your domain name, and your hosting account outright, with nothing rented and no monthly website subscription. Most builders keep you paying every month for a site that is not truly yours, and if you stop paying it often disappears. I build in clean code that belongs to your business, so if you ever decide to work with someone else, you can take your site with you.",
  },
];
---

<Layout
  title="San Bernardino Web Design for Contractors and Local Service Businesses"
  description="Custom websites for San Bernardino contractors and local service businesses. Based in Big Bear, just up the mountain, serving San Bernardino as a service area business. You own everything; no monthly rental. Built in the USA."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "@id": "https://reynahouse.ai/inland-empire/san-bernardino/#service",
      "name": "Website Design for San Bernardino Service Businesses",
      "serviceType": "Website design for local service businesses",
      "provider": { "@id": "https://reynahouse.ai/#org" },
      "areaServed": {
        "@type": "City",
        "name": "San Bernardino",
      },
      "description": "Custom coded websites for San Bernardino contractors and local service businesses. The owner keeps the code, domain, and hosting outright.",
      "url": "https://reynahouse.ai/inland-empire/san-bernardino/",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://reynahouse.ai/" },
        { "@type": "ListItem", "position": 2, "name": "Inland Empire Web Design", "item": "https://reynahouse.ai/inland-empire/" },
        { "@type": "ListItem", "position": 3, "name": "San Bernardino", "item": "https://reynahouse.ai/inland-empire/san-bernardino/" },
      ],
    })} />
  </Fragment>

  <Header />

  <main class="page">
    <!-- HERO -->
    <article class="intro">
      <div class="intro__container">
        <nav class="crumbs" aria-label="Breadcrumb">
          <a href="/">Home</a> <span aria-hidden="true">/</span> <a href="/inland-empire/">Inland Empire</a> <span aria-hidden="true">/</span> San Bernardino
        </nav>
        <span class="overline">FOR SAN BERNARDINO SERVICE BUSINESSES</span>
        <h1 class="h1">Website Design for San Bernardino Contractors and Local Service Businesses</h1>
        <p class="lede">
          I build fast, owned websites for San Bernardino contractors, trades, and
          local service businesses that make it easier for customers to call,
          request service, and trust your business before booking. Based in Big
          Bear, just up the mountain, so San Bernardino is home turf.
        </p>
        <p class="body body--gold">
          No Wix. No platform rental. You own your site, your domain, and your data,
          and it is built around the San Bernardino searches your customers actually
          make.
        </p>
      </div>
    </article>

    <!-- WHY -->
    <section class="section">
      <div class="section__container">
        <h2 class="h2">Why San Bernardino Businesses Need This</h2>
        <p class="body">
          San Bernardino is the county seat and one of the busiest service markets
          in the Inland Empire, full of established contractors competing for the
          same local searches. Your next customer usually searches Google before
          they call, and the business with the clearer, faster website tends to win
          the job.
        </p>
        <p class="body">
          A lot of solid local shops still run on a slow, dated website that hides
          on a phone screen. A site built the right way helps San Bernardino
          customers find you first and makes it dead simple to tap and call, so the
          work does not go to the next company on the list.
        </p>
      </div>
    </section>

    <!-- PROOF -->
    <section class="section section--tint">
      <div class="section__container">
        <h2 class="h2">Sites I Have Built for Inland Empire Trades</h2>
        <p class="body">
          Here are working websites I built and put online as examples of what I
          would build for a San Bernardino business, including a concrete contractor
          site built for this market.
        </p>
        <div class="proof-grid proof-grid--two">
          {proof.map((p) => (
            <a href={p.href} class="proof" target="_blank" rel="noopener noreferrer">
              <span class="proof__frame">
                <Image
                  src={p.img}
                  alt={`Screenshot of a live ${p.label} website I built`}
                  widths={[420, 640, 860]}
                  sizes="(max-width: 700px) 92vw, 440px"
                  width={860}
                  height={573}
                  loading="lazy"
                  decoding="async"
                />
              </span>
              <span class="proof__label">{p.label}</span>
              <span class="proof__note">{p.note}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- WHO -->
    <section class="section">
      <div class="section__container">
        <h2 class="h2">Who I Build For in San Bernardino</h2>
        <div class="trades">
          {trades.map((t) => <span class="trade">{t}</span>)}
        </div>
        <p class="body trades__note">
          If your San Bernardino business depends on local customers finding you
          online, I can build a website designed around that goal.
        </p>
      </div>
    </section>

    <!-- SERVICES + LINKS -->
    <section class="section section--tint">
      <div class="section__container">
        <h2 class="h2">What You Get</h2>
        <p class="body">
          A custom multi page website built around your services and your San
          Bernardino service area, with mobile first design, Google Business Profile
          integration, tap to call, a quote request form, and clean local SEO
          structure. Most sites are live in about a week. When you are ready, add AI
          phone answering, missed call text back, a website chatbot, and lead
          tracking.
        </p>
        <div class="related__grid related__grid--four">
          <a class="related__card" href="/inland-empire/"><span>Inland Empire Hub</span></a>
          <a class="related__card" href="/websites-for-concrete/"><span>Concrete Contractors</span></a>
          <a class="related__card" href="/websites-for-contractors/"><span>Contractors</span></a>
          <a class="related__card" href="/websites-for-roofers/"><span>Roofers</span></a>
          <a class="related__card" href="/websites-for-hvac/"><span>HVAC Contractors</span></a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section section--cta">
      <div class="section__container">
        <h2 class="h2">Ready for More San Bernardino Calls?</h2>
        <p class="body">
          Tell me your services and your San Bernardino service area, and I'll show
          you what a website built for Google Search can do for your phone. Book a
          free call; no pressure, no obligation.
        </p>
        <div class="cta__actions">
          <a href="/#contact" class="btn btn--primary">Book a Free Call &rarr;</a>
          <a href="tel:+19093410243" class="btn btn--ghost">Or call 909-341-0243</a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section section--tint">
      <div class="section__container section__container--narrow">
        <h2 class="h2">Common Questions From San Bernardino Businesses</h2>
        {faqs.map((f) => (
          <details class="faq">
            <summary class="faq__q">{f.q}</summary>
            <p class="faq__a">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- RELATED -->
    <section class="related">
      <div class="related__container">
        <p class="related__title">Keep Reading</p>
        <div class="related__grid">
          <a class="related__card" href="/inland-empire/">
            <span>Inland Empire Web Design</span>
            <small>The full regional hub and every city I serve.</small>
          </a>
          <a class="related__card" href="/inland-empire/riverside/">
            <span>Riverside Web Design</span>
            <small>Websites for Riverside contractors and service businesses.</small>
          </a>
          <a class="related__card" href="/missed-call-text-back/">
            <span>Missed Call Text Back</span>
            <small>Stop losing jobs to voicemail when you can't pick up.</small>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page { background-color: var(--white); }
  .intro { background: linear-gradient(135deg, var(--navy) 0%, #1a1a2e 100%); padding: 72px 24px 64px; }
  .intro__container { max-width: 820px; margin: 0 auto; }
  .crumbs { font-family: 'IBM Plex Mono', monospace; font-size: 0.75rem; color: var(--tan); margin-bottom: 24px; }
  .crumbs a { color: var(--copper-light); }
  .crumbs a:hover { color: var(--copper); }
  .overline { display: block; font-family: 'IBM Plex Mono', monospace; color: var(--copper-light); text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.75rem; margin-bottom: 16px; }
  .h1 { font-family: 'Bebas Neue', sans-serif; color: var(--white); font-size: clamp(2.2rem, 6vw, 3.6rem); line-height: 1.05; margin-bottom: 24px; }
  .lede { font-family: 'Inter', sans-serif; color: var(--white); font-size: 1.15rem; line-height: 1.7; margin-bottom: 16px; }
  .section { padding: 64px 24px; }
  .section--tint { background-color: var(--cream); }
  .section--dark { background: linear-gradient(135deg, var(--forest) 0%, #1a2a1c 100%); }
  .section--cta { background-color: var(--white); text-align: center; }
  .section__container { max-width: 920px; margin: 0 auto; }
  .section__container--narrow { max-width: 760px; }
  .h2 { font-family: 'Bebas Neue', sans-serif; color: var(--navy); font-size: clamp(1.8rem, 4.5vw, 2.6rem); line-height: 1.1; margin-bottom: 20px; }
  .h2--light { color: var(--white); }
  .body { font-family: 'Inter', sans-serif; color: var(--dark); font-size: 1.05rem; line-height: 1.75; margin-bottom: 16px; }
  .body--light { color: var(--cream); }
  .body--gold { color: var(--gold); font-weight: 600; }
  .inline-link { color: var(--copper-dark); font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }
  .inline-link:hover { color: var(--copper); }

  .proof-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 28px; }
  .proof-grid--two { grid-template-columns: repeat(2, 1fr); }
  .proof { display: block; background: var(--white); border: 1px solid var(--tan); border-radius: 10px; overflow: hidden; transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.2s ease; }
  .proof:hover { box-shadow: 0 12px 28px rgba(0, 0, 0, 0.14); transform: translateY(-3px); border-color: var(--copper); }
  .proof__frame { display: block; }
  .proof__frame img { width: 100%; height: auto; display: block; }
  .proof__label { display: block; font-family: 'IBM Plex Mono', monospace; color: var(--copper-dark); font-size: 0.78rem; padding: 14px 16px 4px; }
  .proof__note { display: block; font-family: 'Inter', sans-serif; color: var(--dark); font-size: 0.88rem; line-height: 1.5; padding: 0 16px 18px; }

  .trades { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }
  .trade { font-family: 'Inter', sans-serif; font-size: 0.92rem; color: var(--navy); background: var(--cream); border: 1px solid var(--tan); border-radius: 999px; padding: 8px 16px; }
  .section--tint .trade { background: var(--white); }
  .trades__note { margin-top: 28px; }

  .cta__actions { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; margin-top: 28px; }
  .btn { font-family: 'Inter', sans-serif; font-weight: 600; font-size: 1rem; padding: 14px 26px; border-radius: 8px; transition: background-color 0.2s ease, color 0.2s ease; }
  .btn--primary { background-color: var(--copper); color: var(--white); }
  .btn--primary:hover { background-color: #b8843f; }
  .btn--ghost { border: 1px solid var(--navy); color: var(--navy); }
  .btn--ghost:hover { background-color: var(--navy); color: var(--white); }
  .btn:focus-visible { outline: 2px solid var(--copper); outline-offset: 2px; }

  .faq { border-bottom: 1px solid var(--tan); padding: 16px 0; }
  .faq__q { font-family: 'IBM Plex Mono', monospace; color: var(--copper-dark); font-size: 0.95rem; cursor: pointer; list-style: none; padding: 4px 0; }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::before { content: '+ '; font-weight: 700; }
  details[open] .faq__q::before { content: '− '; }
  .faq__a { font-family: 'Inter', sans-serif; color: var(--navy); font-size: 0.97rem; line-height: 1.7; padding: 12px 0 4px; }

  .related { background: var(--cream); padding: 48px 24px; }
  .related__container { max-width: 920px; margin: 0 auto; }
  .related__title { font-family: 'IBM Plex Mono', monospace; color: var(--copper-dark); font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
  .related__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .related__grid--four { grid-template-columns: repeat(5, 1fr); }
  .related__card { display: block; background: var(--white); border: 1px solid var(--tan); border-radius: 10px; padding: 18px; transition: border-color 0.2s ease; }
  .related__card:hover { border-color: var(--copper); }
  .related__card span { font-family: 'Inter', sans-serif; font-weight: 600; color: var(--navy); font-size: 1rem; line-height: 1.3; }
  .related__card small { display: block; font-family: 'Inter', sans-serif; color: var(--dark); font-size: 0.85rem; margin-top: 6px; line-height: 1.5; }

  @media (max-width: 700px) {
    .proof-grid { grid-template-columns: 1fr; }
    .proof-grid--two { grid-template-columns: 1fr; }
    .related__grid { grid-template-columns: 1fr; }
    .related__grid--four { grid-template-columns: 1fr; }
  }
</style>
