---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ridgelineShot from '../../assets/images/ridgeline_hvac_hero.jpg';
import summitShot from '../../assets/images/summit_line_roofing_hero.jpg';

const trades = [
  "General contractors", "Plumbers", "HVAC companies", "Roofers",
  "Electricians", "Landscapers", "Painters", "Remodelers",
  "Hair salons", "Cleaning companies",
];

const proof = [
  {
    img: ridgelineShot,
    href: "https://ridgeline-hvac-showcase.netlify.app/",
    label: "HVAC company · Inland Empire",
    note: "An Inland Empire HVAC site with a service page for every job and fast tap to call for the emergencies that come in from a phone.",
  },
  {
    img: summitShot,
    href: "https://summit-line-roofing-showcase.netlify.app/",
    label: "Roofing company · Southern California",
    note: "A Southern California roofing site built for storm season searches and clear, easy estimate requests.",
  },
];

const faqs = [
  {
    q: "Can you build a website for my Riverside business if you are not in Riverside?",
    a: "Yes. I build websites for Riverside contractors and local service businesses through a remote first process, and being up in Big Bear changes nothing about the result. Everything is handled by phone, text, email, and video call, so we never need to meet in person. On our first call I learn your Riverside service area and the work you want more of, then I build your site around the local searches your customers actually make.",
  },
  {
    q: "Which Riverside businesses do you build websites for?",
    a: "I build websites for Riverside service businesses of almost every kind, including contractors, plumbers, HVAC companies, roofers, electricians, landscapers, painters, remodelers, and hair salons. The common thread is simple: if your customers find you by searching online and then calling, a website built the right way will bring you more of them. Riverside is a big, competitive market, so the site is built around the exact services and neighborhoods you want to win.",
  },
  {
    q: "How do you help a Riverside business show up on Google?",
    a: "I build your Riverside website around the searches your customers actually type, then structure it so Google understands your services, your service area, and how to reach you. That means clean local SEO structure, Google Business Profile integration, fast mobile pages, and clear service pages for the work you want more of. I do not sell magic rankings; I build the honest foundation that gives a Riverside business a real chance to be found and called.",
  },
  {
    q: "What does a Riverside website cost?",
    a: "A custom website you own outright usually lands between a cheap monthly builder and a big agency, priced as one fixed number scoped to your business. On the low end, builders like Wix run about $30 a month forever and you never own the site; on the high end, large agencies charge $10,000 or more with an ongoing retainer. What moves the number is straightforward: how many service pages you need, how many areas you serve, and whether you want extras like online booking or missed call text back. I give you one honest price on a free call, with no surprises later.",
  },
  {
    q: "Will I own my Riverside website?",
    a: "Yes. You own the code, your domain name, and your hosting account outright, with nothing rented and no monthly website subscription. Most builders keep you paying every month for a site that is not truly yours, and if you stop paying it often disappears. I build in clean code that belongs to your business, so if you ever decide to work with someone else, you can take your Riverside site with you.",
  },
];
---

<Layout
  title="Riverside Web Design for Contractors and Local Service Businesses"
  description="Custom websites for Riverside contractors and local service businesses through a remote first build process. Based in Big Bear, serving Riverside and the Inland Empire. You own everything; no monthly rental. Built in the USA."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "@id": "https://reynahouse.ai/inland-empire/riverside/#service",
      "name": "Website Design for Riverside Service Businesses",
      "serviceType": "Website design for local service businesses",
      "provider": { "@id": "https://reynahouse.ai/#org" },
      "areaServed": {
        "@type": "City",
        "name": "Riverside",
      },
      "description": "Custom coded websites for Riverside contractors and local service businesses, built through a remote first process. The owner keeps the code, domain, and hosting outright.",
      "url": "https://reynahouse.ai/inland-empire/riverside/",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://reynahouse.ai/" },
        { "@type": "ListItem", "position": 2, "name": "Inland Empire Web Design", "item": "https://reynahouse.ai/inland-empire/" },
        { "@type": "ListItem", "position": 3, "name": "Riverside", "item": "https://reynahouse.ai/inland-empire/riverside/" },
      ],
    })} />
  </Fragment>

  <Header />

  <main class="page">
    <!-- HERO -->
    <article class="intro">
      <div class="intro__container">
        <nav class="crumbs" aria-label="Breadcrumb">
          <a href="/">Home</a> <span aria-hidden="true">/</span> <a href="/inland-empire/">Inland Empire</a> <span aria-hidden="true">/</span> Riverside
        </nav>
        <span class="overline">FOR RIVERSIDE SERVICE BUSINESSES</span>
        <h1 class="h1">Website Design for Riverside Contractors and Local Service Businesses</h1>
        <p class="lede">
          I build fast, owned websites for Riverside contractors, trades, and local
          service businesses through a remote first process. Based in Big Bear,
          serving Riverside and the wider Inland Empire, with the whole build handled
          by phone, text, email, and screen share.
        </p>
        <p class="body body--gold">
          No Wix. No platform rental. You own your site, your domain, and your data,
          and it is built around the Riverside searches your customers actually make.
        </p>
      </div>
    </article>

    <!-- WHY -->
    <section class="section">
      <div class="section__container">
        <h2 class="h2">Why Riverside Businesses Need This</h2>
        <p class="body">
          Riverside is the largest city in the Inland Empire and one of its most
          competitive service markets, which means more customers searching and more
          companies fighting for the same clicks. Your next customer usually checks
          Google before they call, and the business with the clearer, faster website
          tends to get chosen.
        </p>
        <p class="body">
          If your Riverside business is stuck on a slow or dated site, you are
          handing those searches to a competitor. A website built the right way
          helps customers find you first and makes it dead simple to tap and call,
          so the job does not slip to the next name on the list.
        </p>
      </div>
    </section>

    <!-- PROOF -->
    <section class="section section--tint">
      <div class="section__container">
        <h2 class="h2">Sites I Have Built for Inland Empire Trades</h2>
        <p class="body">
          These are working websites I built and put online as examples of the kind
          of site I would build for a Riverside business; the same custom coded
          approach, applied to your services and your market.
        </p>
        <div class="proof-grid proof-grid--two">
          {proof.map((p) => (
            <a href={p.href} class="proof" target="_blank" rel="noopener noreferrer">
              <span class="proof__frame">
                <Image
                  src={p.img}
                  alt={`Screenshot of a live ${p.label} website I built`}
                  widths={[420, 640, 860]}
                  sizes="(max-width: 700px) 92vw, 440px"
                  width={860}
                  height={573}
                  loading="lazy"
                  decoding="async"
                />
              </span>
              <span class="proof__label">{p.label}</span>
              <span class="proof__note">{p.note}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- WHO -->
    <section class="section">
      <div class="section__container">
        <h2 class="h2">Who I Build For in Riverside</h2>
        <div class="trades">
          {trades.map((t) => <span class="trade">{t}</span>)}
        </div>
        <p class="body trades__note">
          If your Riverside business depends on local customers finding you online,
          I can build a website designed around that goal.
        </p>
      </div>
    </section>

    <!-- SERVICES + LINKS -->
    <section class="section section--tint">
      <div class="section__container">
        <h2 class="h2">What You Get</h2>
        <p class="body">
          A custom multi page website built around your services and your Riverside
          service area, with mobile first design, Google Business Profile
          integration, tap to call, a quote request form, and clean local SEO
          structure. Most sites are live in about a week. When you are ready, add AI
          phone answering, missed call text back, a website chatbot, and lead
          tracking.
        </p>
        <div class="related__grid related__grid--four">
          <a class="related__card" href="/inland-empire/"><span>Inland Empire Hub</span></a>
          <a class="related__card" href="/websites-for-contractors/"><span>Contractors</span></a>
          <a class="related__card" href="/websites-for-plumbers/"><span>Plumbers</span></a>
          <a class="related__card" href="/websites-for-hvac/"><span>HVAC Contractors</span></a>
          <a class="related__card" href="/websites-for-electricians/"><span>Electricians</span></a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section section--cta">
      <div class="section__container">
        <h2 class="h2">Ready for More Riverside Calls?</h2>
        <p class="body">
          Tell me your services and your Riverside service area, and I'll show you
          what a website built for Google Search can do for your phone. Book a free
          call; no pressure, no obligation.
        </p>
        <div class="cta__actions">
          <a href="/#contact" class="btn btn--primary">Book a Free Call &rarr;</a>
          <a href="tel:+19093410243" class="btn btn--ghost">Or call 909-341-0243</a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section section--tint">
      <div class="section__container section__container--narrow">
        <h2 class="h2">Common Questions From Riverside Businesses</h2>
        {faqs.map((f) => (
          <details class="faq">
            <summary class="faq__q">{f.q}</summary>
            <p class="faq__a">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- RELATED -->
    <section class="related">
      <div class="related__container">
        <p class="related__title">Keep Reading</p>
        <div class="related__grid">
          <a class="related__card" href="/inland-empire/">
            <span>Inland Empire Web Design</span>
            <small>The full regional hub and every city I serve.</small>
          </a>
          <a class="related__card" href="/inland-empire/san-bernardino/">
            <span>San Bernardino Web Design</span>
            <small>Websites for San Bernardino contractors and service businesses.</small>
          </a>
          <a class="related__card" href="/why-not-showing-on-google/">
            <span>Why Isn't My Business on Google?</span>
            <small>The usual reasons, and how to fix them.</small>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page { background-color: var(--white); }
  .intro { background: linear-gradient(135deg, var(--navy) 0%, #1a1a2e 100%); padding: 72px 24px 64px; }
  .intro__container { max-width: 820px; margin: 0 auto; }
  .crumbs { font-family: 'IBM Plex Mono', monospace; font-size: 0.75rem; color: var(--tan); margin-bottom: 24px; }
  .crumbs a { color: var(--copper-light); }
  .crumbs a:hover { color: var(--copper); }
  .overline { display: block; font-family: 'IBM Plex Mono', monospace; color: var(--copper-light); text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.75rem; margin-bottom: 16px; }
  .h1 { font-family: 'Bebas Neue', sans-serif; color: var(--white); font-size: clamp(2.2rem, 6vw, 3.6rem); line-height: 1.05; margin-bottom: 24px; }
  .lede { font-family: 'Inter', sans-serif; color: var(--white); font-size: 1.15rem; line-height: 1.7; margin-bottom: 16px; }
  .section { padding: 64px 24px; }
  .section--tint { background-color: var(--cream); }
  .section--dark { background: linear-gradient(135deg, var(--forest) 0%, #1a2a1c 100%); }
  .section--cta { background-color: var(--white); text-align: center; }
  .section__container { max-width: 920px; margin: 0 auto; }
  .section__container--narrow { max-width: 760px; }
  .h2 { font-family: 'Bebas Neue', sans-serif; color: var(--navy); font-size: clamp(1.8rem, 4.5vw, 2.6rem); line-height: 1.1; margin-bottom: 20px; }
  .h2--light { color: var(--white); }
  .body { font-family: 'Inter', sans-serif; color: var(--dark); font-size: 1.05rem; line-height: 1.75; margin-bottom: 16px; }
  .body--light { color: var(--cream); }
  .body--gold { color: var(--gold); font-weight: 600; }
  .inline-link { color: var(--copper-dark); font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }
  .inline-link:hover { color: var(--copper); }

  .proof-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 28px; }
  .proof-grid--two { grid-template-columns: repeat(2, 1fr); }
  .proof { display: block; background: var(--white); border: 1px solid var(--tan); border-radius: 10px; overflow: hidden; transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.2s ease; }
  .proof:hover { box-shadow: 0 12px 28px rgba(0, 0, 0, 0.14); transform: translateY(-3px); border-color: var(--copper); }
  .proof__frame { display: block; }
  .proof__frame img { width: 100%; height: auto; display: block; }
  .proof__label { display: block; font-family: 'IBM Plex Mono', monospace; color: var(--copper-dark); font-size: 0.78rem; padding: 14px 16px 4px; }
  .proof__note { display: block; font-family: 'Inter', sans-serif; color: var(--dark); font-size: 0.88rem; line-height: 1.5; padding: 0 16px 18px; }

  .trades { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }
  .trade { font-family: 'Inter', sans-serif; font-size: 0.92rem; color: var(--navy); background: var(--cream); border: 1px solid var(--tan); border-radius: 999px; padding: 8px 16px; }
  .section--tint .trade { background: var(--white); }
  .trades__note { margin-top: 28px; }

  .cta__actions { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; margin-top: 28px; }
  .btn { font-family: 'Inter', sans-serif; font-weight: 600; font-size: 1rem; padding: 14px 26px; border-radius: 8px; transition: background-color 0.2s ease, color 0.2s ease; }
  .btn--primary { background-color: var(--copper); color: var(--white); }
  .btn--primary:hover { background-color: #b8843f; }
  .btn--ghost { border: 1px solid var(--navy); color: var(--navy); }
  .btn--ghost:hover { background-color: var(--navy); color: var(--white); }
  .btn:focus-visible { outline: 2px solid var(--copper); outline-offset: 2px; }

  .faq { border-bottom: 1px solid var(--tan); padding: 16px 0; }
  .faq__q { font-family: 'IBM Plex Mono', monospace; color: var(--copper-dark); font-size: 0.95rem; cursor: pointer; list-style: none; padding: 4px 0; }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::before { content: '+ '; font-weight: 700; }
  details[open] .faq__q::before { content: '− '; }
  .faq__a { font-family: 'Inter', sans-serif; color: var(--navy); font-size: 0.97rem; line-height: 1.7; padding: 12px 0 4px; }

  .related { background: var(--cream); padding: 48px 24px; }
  .related__container { max-width: 920px; margin: 0 auto; }
  .related__title { font-family: 'IBM Plex Mono', monospace; color: var(--copper-dark); font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
  .related__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .related__grid--four { grid-template-columns: repeat(5, 1fr); }
  .related__card { display: block; background: var(--white); border: 1px solid var(--tan); border-radius: 10px; padding: 18px; transition: border-color 0.2s ease; }
  .related__card:hover { border-color: var(--copper); }
  .related__card span { font-family: 'Inter', sans-serif; font-weight: 600; color: var(--navy); font-size: 1rem; line-height: 1.3; }
  .related__card small { display: block; font-family: 'Inter', sans-serif; color: var(--dark); font-size: 0.85rem; margin-top: 6px; line-height: 1.5; }

  @media (max-width: 700px) {
    .proof-grid { grid-template-columns: 1fr; }
    .proof-grid--two { grid-template-columns: 1fr; }
    .related__grid { grid-template-columns: 1fr; }
    .related__grid--four { grid-template-columns: 1fr; }
  }
</style>
