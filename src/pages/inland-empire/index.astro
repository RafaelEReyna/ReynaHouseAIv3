---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ridgelineShot from '../../assets/images/ridgeline_hvac_hero.jpg';
import bedrockShot from '../../assets/images/bedrock_concrete_hero.jpg';
import summitShot from '../../assets/images/summit_line_roofing_hero.jpg';

const trades = [
  "General contractors", "Plumbers", "HVAC companies", "Roofers",
  "Electricians", "Landscapers", "Painters", "Concrete contractors",
  "Hair salons", "Cleaning companies",
];

const cities = [
  "San Bernardino", "Riverside", "Fontana", "Rancho Cucamonga",
  "Ontario", "Redlands", "Highland", "Upland", "Rialto", "Colton",
];

const proof = [
  {
    img: ridgelineShot,
    href: "https://ridgeline-hvac-showcase.netlify.app/",
    label: "HVAC company · Inland Empire",
    note: "A full HVAC site with a service page for every job, the towns it covers, and fast tap to call.",
  },
  {
    img: bedrockShot,
    href: "https://bedrock-concrete-showcase.netlify.app/",
    label: "Concrete contractor · San Bernardino",
    note: "A concrete contractor site built to turn a search into a quote request.",
  },
  {
    img: summitShot,
    href: "https://summit-line-roofing-showcase.netlify.app/",
    label: "Roofing company · Southern California",
    note: "A roofing site built for storm season searches and clear estimate requests.",
  },
];

const faqs = [
  {
    q: "Do you build websites for businesses in the Inland Empire?",
    a: "Yes. I'm based in Big Bear, California, and I build websites for contractors, trades, and local service businesses across the Inland Empire, including San Bernardino, Riverside, Fontana, Rancho Cucamonga, Ontario, and Redlands. Because everything is done by phone, text, email, and video call, we never need to meet in person and your location is never a problem. On our first call I learn your service area, the work you want more of, and how you take calls. Then I build your website around the local searches your customers actually make, so the people nearby with a problem right now have a better chance of finding you and calling you first.",
  },
  {
    q: "Do you have an office in Riverside or San Bernardino?",
    a: "No. Reyna House AI is based in Big Bear and serves the Inland Empire as a service area business, so there is no storefront in Riverside, San Bernardino, or any other city. That is a good thing for you, because I keep overhead low and put the money into building a website you own outright instead of renting an office. Most Inland Empire projects are handled remotely from start to finish, and you get the same custom coded site, the same honest pricing, and the same person answering when you need something changed.",
  },
  {
    q: "What kind of Inland Empire businesses do you work with?",
    a: "I work with contractors, plumbers, electricians, roofers, HVAC companies, landscapers, painters, concrete contractors, hair salons, and other local service businesses across the Inland Empire. The common thread is simple: if your customers find you by searching online and then calling, a website built the right way will bring you more of them. The work you focus on shapes how I build the site, so an emergency plumber gets a fast tap to call button on every page while a remodeler gets clear service pages that build trust before a decision worth thousands of dollars.",
  },
  {
    q: "Do I have to be local to work with you?",
    a: "No. Most projects are handled by phone, text, email, and screen share, so Inland Empire clients never need to meet in person and clients in other states are just as easy to build for. I learn your services and your service area on a free call, send you a version to review, make your changes, and launch. You are involved at the points that matter and left alone the rest of the time so you can keep running your business.",
  },
  {
    q: "Do clients own the website?",
    a: "Yes. You own the code, your domain name, and your hosting account outright, with nothing rented and no monthly website subscription. Most website builders work differently; you pay every month, but the site is not truly yours, and if you stop paying it often disappears. I build in clean code that belongs to your business, not to me. If you ever decide to work with someone else, you can take your site with you.",
  },
  {
    q: "Can you add AI answering or missed call text back?",
    a: "Yes. I can add AI phone answering, missed call text back, and a website chatbot so more of your calls and form requests get captured instead of lost. For a busy Inland Empire service business, a missed call is usually a missed job, and these systems are built to catch the customer before they call the next company on the list. We start with the website and add the automation you actually want, when you are ready.",
  },
];
---

<Layout
  title="Inland Empire Web Design and AI Automation for Contractors and Service Businesses"
  description="Custom websites and AI automation for Inland Empire contractors, trades, and local service businesses. Based in Big Bear, serving San Bernardino, Riverside, Fontana, and the wider Inland Empire. You own everything; no monthly rental. Built in the USA."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "@id": "https://reynahouse.ai/inland-empire/#service",
      "name": "Website Design and AI Automation for Inland Empire Service Businesses",
      "serviceType": "Website design and AI automation for local service businesses",
      "provider": { "@id": "https://reynahouse.ai/#org" },
      "areaServed": {
        "@type": "AdministrativeArea",
        "name": "Inland Empire",
      },
      "description": "Custom coded websites and AI automation for contractors, trades, and local service businesses across the Inland Empire. The owner keeps the code, domain, and hosting outright.",
      "url": "https://reynahouse.ai/inland-empire/",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://reynahouse.ai/" },
        { "@type": "ListItem", "position": 2, "name": "Inland Empire Web Design", "item": "https://reynahouse.ai/inland-empire/" },
      ],
    })} />
  </Fragment>

  <Header />

  <main class="page">
    <!-- HERO -->
    <article class="intro">
      <div class="intro__container">
        <nav class="crumbs" aria-label="Breadcrumb">
          <a href="/">Home</a> <span aria-hidden="true">/</span> Inland Empire Web Design
        </nav>
        <span class="overline">FOR INLAND EMPIRE SERVICE BUSINESSES</span>
        <h1 class="h1">Website Design and AI Automation for Inland Empire Contractors and Local Service Businesses</h1>
        <p class="lede">
          I build fast, owned websites and AI answering systems for Inland Empire
          contractors, trades, and local service businesses. Based in Big Bear,
          serving San Bernardino, Riverside, Fontana, and the wider Inland Empire,
          with remote builds available anywhere in the country.
        </p>
        <p class="body body--gold">
          No Wix. No platform rental. You own your site, your domain, and your data,
          and it is built to make it dead simple for a nearby customer to find you
          and call you first.
        </p>
      </div>
    </article>

    <!-- WHO THIS IS FOR -->
    <section class="section">
      <div class="section__container">
        <h2 class="h2">Who This Is For</h2>
        <p class="body">
          If your Inland Empire business depends on local customers finding you
          online and then calling, this is built for you.
        </p>
        <div class="trades">
          {trades.map((t) => <span class="trade">{t}</span>)}
        </div>
      </div>
    </section>

    <!-- WHY IE BUSINESSES NEED THIS -->
    <section class="section section--tint">
      <div class="section__container">
        <h2 class="h2">Why Inland Empire Businesses Need This</h2>
        <p class="body">
          Your customers search before they call. When they cannot find you on
          Google, or they land on an old website that loads slowly and looks dated,
          they call the next company on the list, and that job is gone before you
          ever hear the phone ring.
        </p>
        <p class="body">
          A missed call is a missed job. A website built the right way, paired with
          systems that answer the phone and text back when you cannot pick up, keeps
          more of those opportunities from slipping away. That is what every website
          I build is designed to do.
        </p>
      </div>
    </section>

    <!-- LOCAL PROOF -->
    <section class="section">
      <div class="section__container">
        <h2 class="h2">Recent Sites Built for Inland Empire and Southern California Trades</h2>
        <p class="body">
          These are working websites I built and put online as examples of the kind
          of site I would build for your business. Each one is a full site with a
          page for every service, the towns it covers, fast tap to call, and a
          layout made to turn a search into a booked call.
        </p>
        <div class="proof-grid">
          {proof.map((p) => (
            <a href={p.href} class="proof" target="_blank" rel="noopener noreferrer">
              <span class="proof__frame">
                <Image
                  src={p.img}
                  alt={`Screenshot of a live ${p.label} website I built`}
                  widths={[360, 560, 760]}
                  sizes="(max-width: 700px) 92vw, 300px"
                  width={760}
                  height={507}
                  loading="lazy"
                  decoding="async"
                />
              </span>
              <span class="proof__label">{p.label}</span>
              <span class="proof__note">{p.note}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="section section--tint">
      <div class="section__container">
        <h2 class="h2">What I Build</h2>
        <div class="cards">
          <div class="card">
            <h3 class="card__title">Foundation Site</h3>
            <p class="card__body">A custom multi page website built around your services and service area, with mobile first design, Google Business Profile integration, tap to call, and a quote request form. Live in about a week.</p>
          </div>
          <div class="card">
            <h3 class="card__title">Authority Site</h3>
            <p class="card__body">Everything in the Foundation Site plus callback automation, Google Maps and schema markup, and simple lead tracking so you can see what is working.</p>
          </div>
          <div class="card">
            <h3 class="card__title">Monthly Care Plan</h3>
            <p class="card__body">Ongoing support with content updates, uptime monitoring, form testing, and Google review link management, so the site keeps earning after launch.</p>
          </div>
        </div>
        <p class="body trades__note">
          Add ons available when you are ready: AI phone answering and booking,
          missed call text back, a website chatbot, SEO content support, and
          analytics setup.
        </p>
      </div>
    </section>

    <!-- SERVICE AREA -->
    <section class="section">
      <div class="section__container">
        <h2 class="h2">Inland Empire Service Area</h2>
        <p class="body">
          Reyna House AI is based in Big Bear, California and serves service
          businesses throughout the Inland Empire, including these cities and the
          areas around them:
        </p>
        <div class="trades">
          {cities.map((c) => <span class="trade">{c}</span>)}
        </div>
        <p class="body trades__note">
          Not on the list? If you serve customers anywhere in the Inland Empire, or
          anywhere in the country, I can build a website designed around your
          market. <a class="inline-link" href="/#contact">Book a free call</a> and
          tell me where you work.
        </p>
      </div>
    </section>

    <!-- WHY DIFFERENT -->
    <section class="section section--dark">
      <div class="section__container">
        <span class="overline overline--light">WHY MINE IS DIFFERENT</span>
        <h2 class="h2 h2--light">Built in the USA, and You Own It</h2>
        <p class="body body--light">
          Many low cost website companies keep prices down by outsourcing
          development overseas or locking businesses into monthly website rentals.
        </p>
        <p class="body body--light">
          I build every website myself in the United States using clean code. When
          the project is finished, you own it. If you ever need help, I am still
          here because I have earned your business, not because you are trapped.
        </p>
      </div>
    </section>

    <!-- TRADE LINKS -->
    <section class="section section--tint">
      <div class="section__container">
        <h2 class="h2">Pick Your Trade</h2>
        <p class="body">
          Every trade has its own page with the details that matter for that work.
          Start with yours:
        </p>
        <div class="related__grid related__grid--four">
          <a class="related__card" href="/websites-for-contractors/"><span>Contractors</span></a>
          <a class="related__card" href="/websites-for-plumbers/"><span>Plumbers</span></a>
          <a class="related__card" href="/websites-for-hvac/"><span>HVAC Contractors</span></a>
          <a class="related__card" href="/websites-for-roofers/"><span>Roofers</span></a>
          <a class="related__card" href="/websites-for-electricians/"><span>Electricians</span></a>
          <a class="related__card" href="/websites-for-landscapers/"><span>Landscapers</span></a>
          <a class="related__card" href="/websites-for-painters/"><span>Painters</span></a>
          <a class="related__card" href="/websites-for-concrete/"><span>Concrete Contractors</span></a>
          <a class="related__card" href="/websites-for-hair-salons/"><span>Hair Salons</span></a>
          <a class="related__card" href="/websites-for-local-service-businesses/"><span>Every Trade I Build For</span></a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section section--cta">
      <div class="section__container">
        <h2 class="h2">Ready for More Calls?</h2>
        <p class="body">
          Tell me your services and your Inland Empire service area, and I'll show
          you what a website built for Google Search can do for your phone. Book a
          free call; no pressure, no obligation.
        </p>
        <div class="cta__actions">
          <a href="/#contact" class="btn btn--primary">Book a Free Call &rarr;</a>
          <a href="tel:+19093410243" class="btn btn--ghost">Or call 909-341-0243</a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section section--tint">
      <div class="section__container section__container--narrow">
        <h2 class="h2">Common Questions From Inland Empire Businesses</h2>
        {faqs.map((f) => (
          <details class="faq">
            <summary class="faq__q">{f.q}</summary>
            <p class="faq__a">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- RELATED -->
    <section class="related">
      <div class="related__container">
        <p class="related__title">Inland Empire Cities</p>
        <div class="related__grid">
          <a class="related__card" href="/inland-empire/san-bernardino/">
            <span>San Bernardino Web Design</span>
            <small>Websites for San Bernardino contractors and service businesses.</small>
          </a>
          <a class="related__card" href="/inland-empire/riverside/">
            <span>Riverside Web Design</span>
            <small>Websites for Riverside contractors and service businesses.</small>
          </a>
          <a class="related__card" href="/missed-call-text-back/">
            <span>Missed Call Text Back</span>
            <small>Stop losing jobs to voicemail when you can't pick up.</small>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page { background-color: var(--white); }
  .intro { background: linear-gradient(135deg, var(--navy) 0%, #1a1a2e 100%); padding: 72px 24px 64px; }
  .intro__container { max-width: 820px; margin: 0 auto; }
  .crumbs { font-family: 'IBM Plex Mono', monospace; font-size: 0.75rem; color: var(--tan); margin-bottom: 24px; }
  .crumbs a { color: var(--copper-light); }
  .crumbs a:hover { color: var(--copper); }
  .overline { display: block; font-family: 'IBM Plex Mono', monospace; color: var(--copper-light); text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.75rem; margin-bottom: 16px; }
  .overline--light { color: var(--copper-light); }
  .h1 { font-family: 'Bebas Neue', sans-serif; color: var(--white); font-size: clamp(2.2rem, 6vw, 3.6rem); line-height: 1.05; margin-bottom: 24px; }
  .lede { font-family: 'Inter', sans-serif; color: var(--white); font-size: 1.15rem; line-height: 1.7; margin-bottom: 16px; }
  .section { padding: 64px 24px; }
  .section--tint { background-color: var(--cream); }
  .section--dark { background: linear-gradient(135deg, var(--forest) 0%, #1a2a1c 100%); }
  .section--cta { background-color: var(--white); text-align: center; }
  .section__container { max-width: 920px; margin: 0 auto; }
  .section__container--narrow { max-width: 760px; }
  .h2 { font-family: 'Bebas Neue', sans-serif; color: var(--navy); font-size: clamp(1.8rem, 4.5vw, 2.6rem); line-height: 1.1; margin-bottom: 20px; }
  .h2--light { color: var(--white); }
  .body { font-family: 'Inter', sans-serif; color: var(--dark); font-size: 1.05rem; line-height: 1.75; margin-bottom: 16px; }
  .body--light { color: var(--cream); }
  .body--gold { color: var(--gold); font-weight: 600; }
  .inline-link { color: var(--copper-dark); font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }
  .inline-link:hover { color: var(--copper); }

  .proof-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 28px; }
  .proof { display: block; background: var(--white); border: 1px solid var(--tan); border-radius: 10px; overflow: hidden; transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.2s ease; }
  .proof:hover { box-shadow: 0 12px 28px rgba(0, 0, 0, 0.14); transform: translateY(-3px); border-color: var(--copper); }
  .proof__frame { display: block; }
  .proof__frame img { width: 100%; height: auto; display: block; }
  .proof__label { display: block; font-family: 'IBM Plex Mono', monospace; color: var(--copper-dark); font-size: 0.78rem; padding: 14px 16px 4px; }
  .proof__note { display: block; font-family: 'Inter', sans-serif; color: var(--dark); font-size: 0.88rem; line-height: 1.5; padding: 0 16px 18px; }

  .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 28px; }
  .card { background: var(--white); border: 1px solid var(--tan); border-radius: 10px; padding: 24px; }
  .card__title { font-family: 'Bebas Neue', sans-serif; color: var(--navy); font-size: 1.5rem; letter-spacing: 0.02em; margin-bottom: 10px; line-height: 1.1; }
  .card__body { font-family: 'Inter', sans-serif; color: var(--dark); font-size: 0.95rem; line-height: 1.6; }

  .trades { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }
  .trade { font-family: 'Inter', sans-serif; font-size: 0.92rem; color: var(--navy); background: var(--cream); border: 1px solid var(--tan); border-radius: 999px; padding: 8px 16px; }
  .section--tint .trade { background: var(--white); }
  .trades__note { margin-top: 28px; }

  .cta__actions { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; margin-top: 28px; }
  .btn { font-family: 'Inter', sans-serif; font-weight: 600; font-size: 1rem; padding: 14px 26px; border-radius: 8px; transition: background-color 0.2s ease, color 0.2s ease; }
  .btn--primary { background-color: var(--copper); color: var(--white); }
  .btn--primary:hover { background-color: #b8843f; }
  .btn--ghost { border: 1px solid var(--navy); color: var(--navy); }
  .btn--ghost:hover { background-color: var(--navy); color: var(--white); }
  .btn:focus-visible { outline: 2px solid var(--copper); outline-offset: 2px; }

  .faq { border-bottom: 1px solid var(--tan); padding: 16px 0; }
  .faq__q { font-family: 'IBM Plex Mono', monospace; color: var(--copper-dark); font-size: 0.95rem; cursor: pointer; list-style: none; padding: 4px 0; }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::before { content: '+ '; font-weight: 700; }
  details[open] .faq__q::before { content: '− '; }
  .faq__a { font-family: 'Inter', sans-serif; color: var(--navy); font-size: 0.97rem; line-height: 1.7; padding: 12px 0 4px; }

  .related { background: var(--cream); padding: 48px 24px; }
  .related__container { max-width: 920px; margin: 0 auto; }
  .related__title { font-family: 'IBM Plex Mono', monospace; color: var(--copper-dark); font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
  .related__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .related__grid--four { grid-template-columns: repeat(5, 1fr); }
  .related__card { display: block; background: var(--white); border: 1px solid var(--tan); border-radius: 10px; padding: 18px; transition: border-color 0.2s ease; }
  .related__card:hover { border-color: var(--copper); }
  .related__card span { font-family: 'Inter', sans-serif; font-weight: 600; color: var(--navy); font-size: 1rem; line-height: 1.3; }
  .related__card small { display: block; font-family: 'Inter', sans-serif; color: var(--dark); font-size: 0.85rem; margin-top: 6px; line-height: 1.5; }

  @media (max-width: 700px) {
    .proof-grid { grid-template-columns: 1fr; }
    .cards { grid-template-columns: 1fr; }
    .related__grid { grid-template-columns: 1fr; }
    .related__grid--four { grid-template-columns: 1fr; }
  }
</style>
