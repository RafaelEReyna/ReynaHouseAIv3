---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import PainPoint from '../components/PainPoint.astro';
import Difference from '../components/Difference.astro';
import Services from '../components/Services.astro';
import Portfolio from '../components/Portfolio.astro';
import About from '../components/About.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Websites & AI Automation for Contractors"
  description="Reyna House AI builds custom websites and automation for general contractors. You own your site — no Wix, no monthly ransom. Based in Big Bear Lake, CA."
>
  <Header />

  <main>
    <Hero />
    <PainPoint />
    <Difference />
    <Services />
    <Portfolio />
    <About />
    <Testimonials />
    <Contact />
  </main>

  <!-- FAQ Section — visible for users, rich for crawlers -->
  <section id="faq" class="faq">
    <div class="faq__container">
      <h2 class="faq__headline">Frequently Asked Questions</h2>

      <details class="faq__item">
        <summary class="faq__question">Who do you build for?</summary>
        <p class="faq__answer">Small businesses; local trades especially. Plumbers, electricians, landscapers, junk haulers, restaurants, salons, notaries. If you serve customers in your community and they need to find you online, I can help.</p>
      </details>

      <details class="faq__item">
        <summary class="faq__question">Do I own my website if Reyna House builds it?</summary>
        <p class="faq__answer">Yes. You get the code, the domain, and the hosting. It's yours completely. No monthly ransom, no platform lock-in. Stop paying me tomorrow and the site keeps running.</p>
      </details>

      <details class="faq__item">
        <summary class="faq__question">What does "you own it" actually mean?</summary>
        <p class="faq__answer">Three things: the code lives on GitHub under your account, the domain is registered in your name, and the hosting account is yours. If you ever want to walk away or hand the whole thing to another developer, the keys are already in your hand.</p>
      </details>

      <details class="faq__item">
        <summary class="faq__question">How long does it take to build a website?</summary>
        <p class="faq__answer">Most sites are live within 1 week of our first call. Bigger projects take longer; I'll give you a real number on the call, not a guess.</p>
      </details>

      <details class="faq__item">
        <summary class="faq__question">What does a website cost?</summary>
        <p class="faq__answer">Every project is scoped to your business; a one-location landscaper isn't the same job as a multi-location restaurant. Book a free 15-minute call and I'll give you an exact number, no pressure.</p>
      </details>

      <details class="faq__item">
        <summary class="faq__question">What if I don't have a logo or photos?</summary>
        <p class="faq__answer">Not a problem. I can design a logo for you and we can use stock photos for launch, then swap in real ones once you have them. Plenty of clients launch with no logo at all and add it later.</p>
      </details>

      <details class="faq__item">
        <summary class="faq__question">What if I already have a website?</summary>
        <p class="faq__answer">Two options. I can rebuild it from scratch on the same domain; usually the better path if the existing one is on Wix or Squarespace. Or I can audit what you have and tell you what's worth keeping. Either way, the call is free.</p>
      </details>

      <details class="faq__item">
        <summary class="faq__question">How do I update content after launch?</summary>
        <p class="faq__answer">For most clients, I make updates as part of the Care Plan; text me what you want changed and it's live the same day. If you want to edit yourself, I can set you up with a simple editor. Either way, you're not stuck waiting on me.</p>
      </details>

      <details class="faq__item">
        <summary class="faq__question">Do you do AI automations?</summary>
        <p class="faq__answer">Yes. Callback automation (so missed calls get a text back immediately), booking automation (so customers can schedule themselves), and lead tracking. The helpers pick up when you're busy doing your work.</p>
      </details>

      <details class="faq__item">
        <summary class="faq__question">Do I need to be in Big Bear?</summary>
        <p class="faq__answer">No. I'm based in Big Bear, California, but I work with clients nationwide. Everything happens by call, text, and email; you don't need to meet in person.</p>
      </details>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .faq {
    background-color: var(--cream);
    padding: 60px 24px;
  }

  .faq__container {
    max-width: 800px;
    margin: 0 auto;
  }

  .faq__headline {
    font-family: 'Bebas Neue', sans-serif;
    color: var(--navy);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    margin-bottom: 32px;
    text-align: center;
  }

  .faq__item {
    border-bottom: 1px solid var(--tan);
    padding: 16px 0;
  }

  .faq__question {
    font-family: 'IBM Plex Mono', monospace;
    color: var(--copper-dark);
    font-size: 0.95rem;
    cursor: pointer;
    list-style: none;
    padding: 4px 0;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::before {
    content: '+ ';
    font-weight: 700;
  }

  details[open] .faq__question::before {
    content: '− ';
  }

  .faq__answer {
    font-family: 'Inter', sans-serif;
    color: var(--navy);
    font-size: 0.95rem;
    line-height: 1.7;
    padding: 12px 0 4px;
  }
</style>
